# ==========================================
# Authentication
# ==========================================
# Generate a secure random string for signing JWT tokens
JWT_SECRET=<YOUR_JWT_SECRET_KEY_AT_LEAST_32_CHARACTERS_LONG>
            

# ==========================================
# Telegram Bot Configuration
# ==========================================
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=<YOUR_TELEGRAM_BOT_TOKEN>
TELEGRAM_BOT_NAME=<YOUR_TELEGRAM_BOT_USERNAME>


# ==========================================
# Email Settings (SMTP)
# ==========================================
# Credentials for sending email notifications
SMTP_USER=<YOUR_SMTP_EMAIL_ADDRESS>
SMTP_PASS=<YOUR_SMTP_APP_PASSWORD>


# ==========================================
# MinIO Storage Settings
# ==========================================
# The root credentials for your local MinIO instance
# (These defaults are safe to use for local development)
MINIO_ROOT_USER=museum_admin
MINIO_ROOT_PASSWORD=museum_local_dev_password


# ==========================================
# Testing & Debugging
# ==========================================
# (Optional) Redirect all outgoing emails to this address for testing
# If left empty, notifications will be sent to the user's actual email
TEST_EMAIL_OVERRIDE=<YOUR_TEST_EMAIL_ADDRESS_OR_EMPTY>
